# ─── Database ───────────────────────────────────────────────
POSTGRES_USER=jobbot
POSTGRES_PASSWORD=changeme
POSTGRES_DB=jobbot
DATABASE_URL=postgresql+asyncpg://jobbot:changeme@postgres:5432/jobbot

# ─── Redis / Celery ─────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── OpenAI ─────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4.5-mini-2026-03-17

# ─── Email (Gmail App Password or iCloud App-Specific Password)
# Gmail:  myaccount.google.com/apppasswords  → create "JobBot"
# iCloud: appleid.apple.com → App-Specific Passwords
EMAIL_PROVIDER=gmail          # gmail | icloud | smtp
EMAIL_ADDRESS=you@gmail.com
EMAIL_PASSWORD=xxxx-xxxx-xxxx-xxxx
EMAIL_DISPLAY_NAME=            # optional — defaults to name from CV

# Custom SMTP (only if EMAIL_PROVIDER=smtp)
SMTP_HOST=smtp.example.com
SMTP_PORT=587

# ─── App ────────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-random-secret-32chars

# NOTE: Personal info (name, phone, location, LinkedIn, GitHub, etc.)
# is extracted automatically from your uploaded CV — no need to set it here.
