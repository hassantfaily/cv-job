# ─── Database ───────────────────────────────────────────────
POSTGRES_USER=jobbot
POSTGRES_PASSWORD=changeme
POSTGRES_DB=jobbot
DATABASE_URL=postgresql+asyncpg://jobbot:changeme@postgres:5432/jobbot

# ─── Redis / Celery ─────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── Claude API ─────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Your Personal Info (used for auto account creation) ────
USER_FIRST_NAME=Hassan
USER_LAST_NAME=YourLastName
USER_PHONE=+1234567890
USER_LOCATION=Your City, Country
USER_LINKEDIN_URL=https://linkedin.com/in/yourprofile
USER_GITHUB_URL=https://github.com/yourusername
USER_WEBSITE=

# ─── Email (Gmail App Password or iCloud App-Specific Password)
# Gmail: https://myaccount.google.com/apppasswords
# iCloud: https://appleid.apple.com > App-Specific Passwords
EMAIL_PROVIDER=gmail          # gmail | icloud | smtp
EMAIL_ADDRESS=you@gmail.com
EMAIL_PASSWORD=xxxx-xxxx-xxxx-xxxx
EMAIL_DISPLAY_NAME=Hassan YourLastName

# iCloud SMTP (only if EMAIL_PROVIDER=icloud)
ICLOUD_EMAIL=you@icloud.com

# Custom SMTP (only if EMAIL_PROVIDER=smtp)
SMTP_HOST=smtp.example.com
SMTP_PORT=587

# ─── App secrets ────────────────────────────────────────────
SECRET_KEY=change-this-to-a-random-secret-32chars
